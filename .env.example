APP_NAME=HustleSafe
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# Windows + Laragon — SQLSTATE[HY000] [2002] "Only one usage of each socket address (protocol/network address/port) is normally permitted"
# when connecting to MySQL (often on session reads): Windows exhausts ephemeral TCP ports to 127.0.0.1:3306 under dev load.
# Fix (use any combination):
#   1) Prefer socket: set DB_SOCKET to your mysql.sock path (Laragon → bin\mysql\mysql-*\data\ — see my.ini / Laragon docs).
#   2) Reduce DB chatter: SESSION_DRIVER=file (below) and/or QUEUE_CONNECTION=sync while developing.
#   3) Fewer PHP workers: PHP_CLI_SERVER_WORKERS=1 if you use php artisan serve with multiple workers.

SESSION_DRIVER=database
# For local MySQL on Windows, `file` sessions reduce concurrent hits on the `sessions` table and can avoid connection pressure.
# Idle timeout in minutes (10080 ≈ 7 days). Increase further if desired.
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Laravel Reverb (WebSockets for quest chat, etc.) — run `php artisan reverb:start` alongside `php artisan serve`
# Generate keys once: `php artisan key:generate` is for APP_KEY; for Reverb use values from `php artisan reverb:install` or set manually.
REVERB_APP_ID=hustlesafe
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth (login with Google) — optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Cloudinary — Dashboard → Settings → API Keys → "API environment variable"
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set cloud name + key + secret. Uploads use Media Library folders:
#   hustleSafe/profiles   (avatars)
#   hustleSafe/quests     (quest brief attachments)
#   hustleSafe/portfolios (portfolio media)
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER_PROFILES=hustleSafe/profiles
CLOUDINARY_FOLDER_QUESTS=hustleSafe/quests
CLOUDINARY_FOLDER_PORTFOLIOS=hustleSafe/portfolios

# Minimum profile completion % (trust metrics) required to send proposals
# FREELANCER_MIN_PROFILE_PERCENT=55
# Quest budget / quote at or above this (kobo minor units) requires approved "Selfie + ID" verification
# Default 50000000 = ₦500,000
# FREELANCER_HIGH_VALUE_QUEST_BUDGET_MINOR=50000000
