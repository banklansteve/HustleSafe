APP_NAME=HustleSafe
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the same host you open in the browser (e.g. http://127.0.0.1:8000 — not localhost if you use 127.0.0.1)
APP_URL=http://127.0.0.1:8000
# Set FORCE_HTTPS=false in local dev if you ever run with APP_ENV=production on HTTP.
# FORCE_HTTPS=false
# If APP_URL uses https but you browse http://127.0.0.1 in dev, set APP_URL_SCHEME=http so generated URLs match the browser.
# APP_URL_SCHEME=http

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hustlesafe
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=
DB_PERSISTENT=true
# Windows + Laragon: keep DB_SOCKET empty. The app ignores Unix sockets on Windows,
# and local development should use TCP to 127.0.0.1:3306. Persistent PDO
# connections reduce Windows ephemeral port exhaustion during local development.

SESSION_DRIVER=file
# For local MySQL on Windows, file sessions reduce concurrent hits on the sessions table and avoid connection pressure.
# Default idle timeout in minutes for regular users (10080 ≈ 7 days).
# Staff admin (operations) uses ADMIN_SESSION_LIFETIME or 300 minutes (5 hours).
# Super admin uses SUPER_ADMIN_SESSION_LIFETIME (20160 = 14 days).
SESSION_LIFETIME=10080
SUPER_ADMIN_SESSION_LIFETIME=20160
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set true in production behind HTTPS. When unset, secure cookies are enabled only when APP_ENV=production.
# SESSION_SECURE_COOKIE=true

# Use "null" unless Reverb/Pusher is running — otherwise proposal/chat broadcasts can hang requests.
BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
# Use database (or redis) + `php artisan queue:work` — sync blocks award confirmation on slow mail/contract work.
QUEUE_CONNECTION=database

# ── Realtime / WebSockets (pick ONE driver) ─────────────────────────────────────
# Option A — Laravel Reverb (self-hosted, run alongside the app):
#   BROADCAST_CONNECTION=reverb
#   php artisan reverb:start
#
# Option B — Pusher (hosted WebSockets, no reverb:start needed):
#   BROADCAST_CONNECTION=pusher
#   Create a free app at https://dashboard.pusher.com — paste keys below.
#
# Option C — Soketi (self-hosted, Pusher-compatible protocol):
#   BROADCAST_CONNECTION=pusher
#   PUSHER_HOST=127.0.0.1
#   PUSHER_PORT=6001
#   PUSHER_SCHEME=http
#
# HTTP polling (500ms) still delivers chat if WebSockets fail — see SUPPORT_CHAT_POLL_* below.
# BROADCAST_CONNECTION=reverb

REVERB_APP_ID=hustlesafe
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
# WebSocket host = browser hostname (127.0.0.1 or localhost — must match APP_URL host)
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
# Live support needs Reverb running: php artisan reverb:start
# (If Reverb is down, the widget falls back to HTTP polling every ~2s.)

# Pusher / Soketi (only when BROADCAST_CONNECTION=pusher)
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https

# SUPPORT_CHAT_POLL_VISIBLE_MS=300
# SUPPORT_CHAT_POLL_HIDDEN_MS=1500

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Uncomment when using Pusher (must match BROADCAST_CONNECTION=pusher)
# VITE_BROADCAST_DRIVER=pusher
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
# VITE_PUSHER_HOST="${PUSHER_HOST}"
# VITE_PUSHER_PORT="${PUSHER_PORT}"
# VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"

# GIF search for staff chat (use at least one)
TENOR_API_KEY=
GIPHY_API_KEY=

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth (login with Google) — optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Cloudinary — Dashboard → Settings → API Keys → "API environment variable"
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set cloud name + key + secret. Uploads use Media Library folders:
#   hustleSafe/profiles   (avatars)
#   hustleSafe/quests     (quest brief attachments)
#   hustleSafe/portfolios (portfolio media)
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER_PROFILES=hustleSafe/profiles
CLOUDINARY_FOLDER_QUESTS=hustleSafe/quests
CLOUDINARY_FOLDER_PORTFOLIOS=hustleSafe/portfolios

# ── Paystack (sandbox / test mode) ─────────────────────────────────────────────
# Get test keys from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_ENABLED=false
PAYSTACK_MODE=test
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_WEBHOOK_SECRET=
# ESCROW_PAYMENT_DRIVER=paystack
PAYMENT_PLATFORM_FEE_PERCENT=12
QUEST_PLATFORM_FEE_PERCENT_DISPLAY=12
# Minutes after publish before boost upsell email (default 20)
# QUEST_BOOST_UPSELL_EMAIL_DELAY_MINUTES=20
PAYMENT_WITHDRAWAL_MIN_MINOR=100000
PAYMENT_WITHDRAWAL_FEE_MINOR=5000

# Minimum profile completion % (trust metrics) required to send proposals
# FREELANCER_MIN_PROFILE_PERCENT=55
# Quest budget / quote at or above this (kobo minor units) requires approved "Selfie + ID" verification
# Default 50000000 = ₦500,000
# FREELANCER_HIGH_VALUE_QUEST_BUDGET_MINOR=50000000
